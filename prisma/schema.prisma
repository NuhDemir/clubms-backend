generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// IDENTITY CONTEXT
model IdentityUser {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentNumber   String              @unique @map("student_number") @db.VarChar(20)
  email           String              @unique @db.VarChar(255)
  fullName        String              @map("full_name") @db.VarChar(100)
  firebaseUid     String              @unique @map("firebase_uid") @db.VarChar(128)
  emailVerified   Boolean             @default(false) @map("email_verified")
  status          String              @default("ACTIVE") @db.VarChar(20)
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  
  globalRole      IdentityGlobalRole?

  @@map("identity_users")
}

model IdentityGlobalRole {
  id        Int          @id @default(autoincrement())
  userId    String       @unique @map("user_id") @db.Uuid
  roleName  String       @map("role_name") @db.VarChar(50) 
  
  user      IdentityUser @relation(fields: [userId], references: [id])

  @@map("identity_global_roles")
}

/// CLUBS CONTEXT
model ClubsClub {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String            @unique @db.VarChar(100)
  description String            @db.Text
  logoUrl     String?           @map("logo_url") @db.VarChar(255)
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  
  memberships ClubsMembership[]
  documents   ClubsDocument[]

  @@map("clubs_clubs")
}

model ClubsMembership {
  id       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId   String    @map("club_id") @db.Uuid
  userId   String    @map("user_id") @db.Uuid    // SOFT FK
  role     String    @db.VarChar(50)
  joinedAt DateTime  @default(now()) @map("joined_at")
  
  club     ClubsClub @relation(fields: [clubId], references: [id])

  @@unique([clubId, userId])
  @@map("clubs_memberships")
}

model ClubsDocument {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId     String    @map("club_id") @db.Uuid
  title      String    @db.VarChar(150)
  fileUrl    String    @map("file_url") @db.VarChar(255)
  uploadedBy String    @map("uploaded_by") @db.Uuid  // SOFT FK
  createdAt  DateTime  @default(now()) @map("created_at")
  
  club       ClubsClub @relation(fields: [clubId], references: [id])

  @@map("clubs_documents")
}


/// EVENTS CONTEXT
model EventsEvent {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId           String             @map("club_id") @db.Uuid   // SOFT FK
  title            String             @db.VarChar(150)
  description      String             @db.Text
  capacity         Int
  currentAttendees Int                @default(0) @map("current_attendees")
  version          Int                @default(1)
  location         String             @db.VarChar(200)
  latitude         Decimal?           @db.Decimal(10, 8)
  longitude        Decimal?           @db.Decimal(11, 8)
  startTime        DateTime           @map("start_time")
  endTime          DateTime           @map("end_time")
  status           String             @default("DRAFT") @db.VarChar(20)
  createdAt        DateTime           @default(now()) @map("created_at")
  
  attendances      EventsAttendance[]
  eventTags        EventsEventTag[]

  @@map("events_events")
}

model EventsAttendance {
  eventId       String      @map("event_id") @db.Uuid
  userId        String      @map("user_id") @db.Uuid   // SOFT FK
  checkInMethod String      @map("check_in_method") @db.VarChar(50)
  joinedAt      DateTime    @default(now()) @map("joined_at")
  
  event         EventsEvent @relation(fields: [eventId], references: [id])

  @@id([eventId, userId])
  @@map("events_attendances")
}

model EventsTag {
  id        Int              @id @default(autoincrement())
  name      String           @unique @db.VarChar(50)
  
  eventTags EventsEventTag[]

  @@map("events_tags")
}

model EventsEventTag {
  eventId String      @map("event_id") @db.Uuid
  tagId   Int         @map("tag_id")
  
  event   EventsEvent @relation(fields: [eventId], references: [id])
  tag     EventsTag   @relation(fields: [tagId], references: [id])

  @@id([eventId, tagId])
  @@map("events_event_tags")
}

/// INFRASTRUCTURE CONTEXT - Outbox Pattern
model InfrastructureOutboxEvent {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  aggregateType String   @map("aggregate_type") @db.VarChar(50)
  aggregateId   String   @map("aggregate_id") @db.Uuid
  eventType     String   @map("event_type") @db.VarChar(100)
  payload       Json
  published     Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([published, createdAt])
  @@map("infrastructure_outbox_events")
}

/// ANALYTICS CONTEXT - Snapshot Pattern
model AnalyticsClubSnapshot {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId                String   @map("club_id") @db.Uuid // SOFT FK
  snapshotDate          DateTime @map("snapshot_date") @db.Date
  totalMembers          Int      @map("total_members")
  activeMembersCount    Int      @map("active_members_count")
  pendingApplications   Int      @map("pending_applications")
  totalEvents           Int      @map("total_events")
  publishedEvents       Int      @map("published_events")
  completedEvents       Int      @map("completed_events")
  totalAttendances      Int      @map("total_attendances")
  averageAttendanceRate Decimal  @map("average_attendance_rate") @db.Decimal(5, 2)
  growthRate            Decimal? @map("growth_rate") @db.Decimal(5, 2)
  createdAt             DateTime @default(now()) @map("created_at")

  @@unique([clubId, snapshotDate])
  @@index([clubId, snapshotDate])
  @@map("analytics_club_snapshots")
}

model AnalyticsEventSnapshot {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId           String   @map("event_id") @db.Uuid // SOFT FK
  snapshotDate      DateTime @map("snapshot_date") @db.Date
  capacity          Int
  totalAttendees    Int      @map("total_attendees")
  attendanceRate    Decimal  @map("attendance_rate") @db.Decimal(5, 2)
  checkInQRCount    Int      @map("check_in_qr_count")
  checkInGPSCount   Int      @map("check_in_gps_count")
  checkInManualCount Int     @map("check_in_manual_count")
  createdAt         DateTime @default(now()) @map("created_at")

  @@unique([eventId, snapshotDate])
  @@index([eventId, snapshotDate])
  @@map("analytics_event_snapshots")
}

model AnalyticsGlobalSnapshot {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  snapshotDate        DateTime @unique @map("snapshot_date") @db.Date
  totalUsers          Int      @map("total_users")
  activeUsers         Int      @map("active_users")
  totalClubs          Int      @map("total_clubs")
  activeClubs         Int      @map("active_clubs")
  totalEvents         Int      @map("total_events")
  publishedEvents     Int      @map("published_events")
  totalAttendances    Int      @map("total_attendances")
  averageEventCapacity Decimal @map("average_event_capacity") @db.Decimal(8, 2)
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([snapshotDate])
  @@map("analytics_global_snapshots")
}
