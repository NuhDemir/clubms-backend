# Server Configuration
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/clubms_dev?schema=public"

# Redis Configuration
# Option 1: Use REDIS_URL (local development)
REDIS_URL="redis://:password@localhost:6379"

# Option 2: Use separate variables (Render production)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# Firebase Authentication
# Get these from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# QR Code Security
# Generate a strong random string for production
QR_SECRET_BASE=your-super-secret-key-change-this-in-production

# CORS
# Set your frontend URL in production
CORS_ORIGIN=*
