  "main": "index.js",
  "scripts": {
    "start:dev": "nodemon --watch src --ext ts --exec \"ts-node -r tsconfig-paths/register src/main.ts\"",
    "dev": "npm run start:dev",
    "build": "tsc && npx tsc-alias",
    "start": "node dist/main.js",
    "start:prod": "npx prisma migrate deploy && node dist/main.js",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:deploy": "npx prisma migrate deploy",
    "prisma:studio": "npx prisma studio",
    "verify:build": "bash scripts/verify-build.sh",
    "deploy": "bash scripts/quick-deploy.sh"
  },
