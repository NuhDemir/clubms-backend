# Production Environment Variables
# Copy this file to .env in production and fill in the values

# Server
NODE_ENV=production
PORT=10000

# Database (Render will auto-populate this)
DATABASE_URL=postgresql://user:password@host:5432/database

# Redis (Render will auto-populate this as connection string)
# IMPORTANT: Redis eviction policy MUST be set to "noeviction" for BullMQ
# In Render Dashboard: Redis > Settings > Eviction Policy > noeviction
REDIS_URL=redis://default:password@host:6379

# Firebase Authentication
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# QR Code Security (Generate a strong random string)
QR_SECRET_BASE=your-super-secret-key-change-this-in-production

# CORS (Set your frontend URL)
CORS_ORIGIN=https://your-frontend-domain.com

# Optional: Sentry for error tracking
# SENTRY_DSN=https://your-sentry-dsn

# Optional: Log level
LOG_LEVEL=info
